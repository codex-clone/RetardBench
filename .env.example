# Core
RETARDBENCH_DB_URL=sqlite+aiosqlite:///./retardbench.db
RETARDBENCH_LOG_LEVEL=INFO
RETARDBENCH_CACHE_TTL_SECONDS=3600

# Providers
RETARDBENCH_DEFAULT_PROVIDER=ollama
